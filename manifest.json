{
  "manifest_version": 3,
  "name": "BetterStudio",
  "version": "6.0",
  "permissions": ["storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"],
  "web_accessible_resources": [
    {
      "resources": ["themes/*.css", "themes.json", "plugins/*.js", "extensions.json"],
      "matches": ["https://aistudio.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://aistudio.google.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}